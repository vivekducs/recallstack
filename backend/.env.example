# Database configuration (PostgreSQL connection string)
DATABASE_URL="postgresql://username:password@localhost:5432/recallstack_db?schema=public"

# JSON Web Token secret key for session signatures
JWT_SECRET="your-secure-jwt-signing-secret-key-change-in-production"

# Port number for the API server to listen on
PORT=5000

# Node runtime environment (development, production, or test)
NODE_ENV=development

# Allowed CORS Origins (comma-separated if multiple)
FRONTEND_URL="http://localhost:3000,https://recallstack.vercel.app"
