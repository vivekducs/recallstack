{
  "name": "recallstack-backend",
  "version": "1.0.0",
  "description": "RecallStack - Personal Knowledge Management Platform API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "test": "jest --runInBand --detectOpenHandles",
    "lint": "eslint src"
  },
  "dependencies": {
    "@prisma/client": "5.0.0",
    "bcryptjs": "2.4.3",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "ioredis": "5.11.1",
    "jsonwebtoken": "9.0.0",
    "nodemailer": "9.0.1"
  },
  "devDependencies": {
    "eslint": "8.57.0",
    "jest": "30.4.2",
    "nodemon": "3.0.1",
    "prisma": "5.0.0",
    "supertest": "7.2.2"
  }
}
